              },
              {
                "name": "request",
                "value": "",
                "type": "query"
              },
              {
                "name": "version",
                "value": "",
                "type": "query"
              },
              {
                "name": "layers",
                "value": "",
                "type": "query"
              },
              {
                "name": "bbox",
                "value": "",
                "type": "query"
              },
              {
                "name": "crs",
                "value": "",
                "type": "query"
              },
