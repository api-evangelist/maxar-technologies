          "info": {
            "name": "WMS GetCapabilities or GetMap",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://securewatch.maxar.com/earthservice/wmsaccess",
            "params": [
              {
                "name": "service",
                "value": "",
