  "info": {
    "_postman_id": "e9b1c97f-cdaf-425f-85e3-2b728f476106",
    "name": "Vantor Hub Authentication API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Token-issuance service for Vantor Hub (formerly Maxar Developer Portal). Exchanges client credentials for bearer access tokens that authorize every other Hub API (Discovery, Account Services, Streaming). Documented at hub.vantor.com/docs/authentication. Profile derived by API Evangelist from Vantor Hub public docs; field shapes mirror common OAuth 2.0 client credentials and Maxar/MGP_SDK conventions and should be confirmed against live Vantor Hub responses before production use.\n\nContact Support:\n Name: Vantor Support",
      "type": "text/plain"
    }
  }
