{
  "opencollection": "1.0.0",
  "info": {
    "name": "Vantor Hub Account Services API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Accounts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get My Account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.maxar.com/admin/v1/accounts/me"
          },
          "docs": "Get My Account"
        },
        {
          "info": {
            "name": "Get Account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Account"
        }
      ]
    },
    {
      "info": {
        "name": "Users",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Users",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/users",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List Users"
        },
        {
          "info": {
            "name": "Invite User",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/users",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Invite User"
        },
        {
          "info": {
            "name": "Get User",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/users/:userId",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              },
              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get User"
        },
        {
          "info": {
            "name": "Remove User",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/users/:userId",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              },
              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Remove User"
        }
      ]
    },
    {
      "info": {
        "name": "Credits",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Credit Balance",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/credits",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Credit Balance"
        }
      ]
    },
    {
      "info": {
        "name": "API Keys",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List API Keys",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/api-keys",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List API Keys"
        },
        {
          "info": {
            "name": "Create API Key",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/api-keys",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create API Key"
        },
        {
          "info": {
            "name": "Revoke API Key",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.maxar.com/admin/v1/accounts/:accountId/api-keys/:keyId",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              },
              {
                "name": "keyId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Revoke API Key"
        }
      ]
    }
  ],
  "bundled": true
}