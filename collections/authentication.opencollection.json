{
  "opencollection": "1.0.0",
  "info": {
    "name": "Vantor Hub Authentication API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Tokens",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Issue Access Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.maxar.com/auth/v1/token",
            "body": {
              "type": "form-urlencoded",
              "data": []
            }
          },
          "docs": "Exchange client credentials (or a refresh token) for a short-lived bearer access token. Send `application/x-www-form-urlencoded` body with `grant_type=client_credentials` plus `client_id` and `client_secret`, or `grant_type=refresh_token` plus `refresh_token`."
        },
        {
          "info": {
            "name": "Refresh Access Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.maxar.com/auth/v1/token/refresh",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Exchange a refresh token for a new access token."
        },
        {
          "info": {
            "name": "Revoke Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.maxar.com/auth/v1/token/revoke",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Revoke an access or refresh token."
        }
      ]
    },
    {
      "info": {
        "name": "Introspection",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Introspect Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.maxar.com/auth/v1/introspect",
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Return active/inactive status and metadata for a token."
        }
      ]
    }
  ],
  "bundled": true
}